diff -ruN Downloads/ME-Conserved-NLS-main/Packages/Exact_Sol.halfway.py ME-conserved-NLS/Packages/Exact_Sol.halfway.py
--- Downloads/ME-Conserved-NLS-main/Packages/Exact_Sol.halfway.py	1970-01-01 03:00:00
+++ ME-conserved-NLS/Packages/Exact_Sol.halfway.py	2026-04-08 08:08:36
@@ -0,0 +1,41 @@
+from ngsolve import *
+import numpy as np
+
+sech = lambda x_: 1/cosh(x_)
+tanh = lambda x_: sinh(x_)/cosh(x_)
+
+sol_M = 1.2
+sol_N = 1
+J = np.arctanh(2*sol_M*sol_N/(sol_M**2+sol_N**2))
+
+c = -4.0
+L = 40.0
+P = 2*L
+
+def std_soliton(z, t):
+    return exp(1j*(-2*z + 5*t)) * sech(z)
+
+def std_soliton_periodic_approx(t, M=1):
+    return sum(std_soliton(x + m*P - c*t, t) for m in range(-M, M+1))
+
+chx = (exp(x)+exp(-x))/2
+Exact_u_Dict = {
+    'Order2_Soliton': lambda t: (4+3*(exp(8*1j*t)-1)/chx**2)/(
+            2*chx+3/4*(cos(8*t)-1)/chx**3
+        )*exp(1j*t),
+
+    # use M=1 first; if you want extra safety, change to M=2
+    'Standard_Soliton': lambda t: std_soliton_periodic_approx(t, M=2),
+
+    'Bi_Soliton_T_Inv': lambda t: (
+            exp(-1j*sol_M**2*(2-t))*sol_M*sech(sol_M*x) - exp(-1j*sol_N**2*(2-t))*sol_N*sech(sol_N*x))/(
+            np.cosh(J) - np.sinh(J)*(tanh(sol_M*x)*tanh(sol_N*x) + cos((sol_M**2-sol_N**2)*(2-t))*sech(sol_M*x)*sech(sol_N*x))
+        ),
+
+    'Bi_Soliton': lambda t: (
+            exp(1j*sol_M**2*t)*sol_M*sech(sol_M*x) - exp(1j*sol_N**2*t)*sol_N*sech(sol_N*x))/(
+            np.cosh(J) - np.sinh(J)*(tanh(sol_M*x)*tanh(sol_N*x) + cos((sol_M**2-sol_N**2)*t)*sech(sol_M*x)*sech(sol_N*x))
+        ),
+
+    'Soliton': lambda t: 4/(2*exp(x+y-2*np.sqrt(2)*t)+exp(-(x+y-2*np.sqrt(2)*t)))*exp(1j*(t+(x+y)*np.sqrt(2)/2))
+}
diff -ruN Downloads/ME-Conserved-NLS-main/Packages/Exact_Sol.mod1.py ME-conserved-NLS/Packages/Exact_Sol.mod1.py
--- Downloads/ME-Conserved-NLS-main/Packages/Exact_Sol.mod1.py	1970-01-01 03:00:00
+++ ME-conserved-NLS/Packages/Exact_Sol.mod1.py	2026-04-08 08:08:36
@@ -0,0 +1,49 @@
+from ngsolve import *
+import numpy as np
+
+sech = lambda z: 1/cosh(z)
+tanh = lambda z: sinh(z)/cosh(z)
+
+sol_M = 1.2
+sol_N = 1
+J = np.arctanh(2*sol_M*sol_N/(sol_M**2+sol_N**2))
+
+L = 40.0
+xmin = -L
+xmax =  L
+period = xmax - xmin
+
+c = -4.0
+
+def wrap_periodic_1d(z):
+    # map z back into [xmin, xmax], assuming at most one crossing
+    return IfPos(z - xmax,
+                 z - period,
+                 IfPos(xmin - z,
+                       z + period,
+                       z))
+
+chx = (exp(x)+exp(-x))/2
+
+Exact_u_Dict = {
+    'Order2_Soliton': lambda t: (4+3*(exp(8*1j*t)-1)/chx**2)/(
+            2*chx+3/4*(cos(8*t)-1)/chx**3
+        )*exp(1j*t),
+
+    'Standard_Soliton': lambda t: (
+        exp(1j*(-2*wrap_periodic_1d(x - c*t) + 5*t))
+        * sech(wrap_periodic_1d(x - c*t))
+    ),
+
+    'Bi_Soliton_T_Inv': lambda t: (
+            exp(-1j*sol_M**2*(2-t))*sol_M*sech(sol_M*x) - exp(-1j*sol_N**2*(2-t))*sol_N*sech(sol_N*x))/(
+            np.cosh(J) - np.sinh(J)*(tanh(sol_M*x)*tanh(sol_N*x) + cos((sol_M**2-sol_N**2)*(2-t))*sech(sol_M*x)*sech(sol_N*x))
+        ),
+
+    'Bi_Soliton': lambda t: (
+            exp(1j*sol_M**2*t)*sol_M*sech(sol_M*x) - exp(1j*sol_N**2*t)*sol_N*sech(sol_N*x))/(
+            np.cosh(J) - np.sinh(J)*(tanh(sol_M*x)*tanh(sol_N*x) + cos((sol_M**2-sol_N**2)*t)*sech(sol_M*x)*sech(sol_N*x))
+        ),
+
+    'Soliton': lambda t: 4/(2*exp(x+y-2*np.sqrt(2)*t)+exp(-(x+y-2*np.sqrt(2)*t)))*exp(1j*(t+(x+y)*np.sqrt(2)/2))
+}
