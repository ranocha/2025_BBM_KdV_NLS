+from ngsolve import *
+import numpy as np
+
+sech = lambda x_: 1/cosh(x_)
+tanh = lambda x_: sinh(x_)/cosh(x_)
+
+sol_M = 1.2
+sol_N = 1
+J = np.arctanh(2*sol_M*sol_N/(sol_M**2+sol_N**2))
+
+c = -4.0
+L = 40.0
+xmax = L
+xmin = -L
+period = xmax - xmin
+
+def wrap_periodic_1d(z, max_wraps=60):
+    """
+    Wrap z back into [xmin, xmax] by repeatedly shifting by one period.
+    max_wraps just needs to be large enough for the largest time of interest.
+    For T <= 1000 here, 60 is plenty.
+    """
+    zz = z
+    for _ in range(max_wraps):
+        zz = IfPos(zz - xmax, zz - period, zz)
+        zz = IfPos(xmin - zz, zz + period, zz)
+    return zz
+
+chx = (exp(x)+exp(-x))/2
+
+Exact_u_Dict = {
+    'Order2_Soliton': lambda t: (4+3*(exp(8*1j*t)-1)/chx**2)/(
